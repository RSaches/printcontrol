{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PrintControl",
  "version": "0.2.3",
  "identifier": "com.printcontrol.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PrintControl",
        "decorations": false,
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset: https://asset.localhost; connect-src ipc: http://ipc.localhost"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkgNkMxOTdBRjM5NUUzMDczQQpSV1E2QitPVjgzb1piQXgyQU1UWjQ1VVJLKy9oSHZhYmRud2MzaFlQb0JVMGNyQldmNnRzT1BKSAo=",
      "endpoints": [
        "https://github.com/RSaches/printcontrol/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "deb", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "SanchesRaffael",
    "category": "Utility",
    "copyright": "© 2026 SanchesRaffael — Licença MIT (Software Livre)",
    "shortDescription": "Monitor de impressão gratuito e open-source.",
    "longDescription": "PrintControl é um software livre projetado para monitorar atividades de impressão em tempo real, fornecendo estatísticas e histórico de forma simples e transparente.",
    "createUpdaterArtifacts": true,
    "licenseFile": "../LICENSE.txt",
    "resources": [
      "resources/**/*"
    ],
    "windows": {
      "allowDowngrades": true,
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "digestAlgorithm": "sha256",
      "timestampUrl": "http://timestamp.comodoca.com",
      "nsis": {
        "installMode": "perMachine",
        "languages": ["PortugueseBR"],
        "displayLanguageSelector": false,
        "installerIcon": "./icons/icon.ico",
        "startMenuFolder": "PrintControl",
        "compression": "lzma",
        "minimumWebview2Version": "110.0.1531.0",
        "installerHooks": "./windows/hooks.nsh"
      },
      "wix": {
        "language": {
          "pt-BR": { "localePath": "./wix/locales/pt-BR.wxl" }
        }
      }
    }
  }
}
